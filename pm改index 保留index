                card.className = 'business-item';
                card.innerHTML = `
                    <h3>${b.title}</h3>
                    <p>${b.desc}</p>
                    <a onclick="openDetailModal(${b.id}); event.stopImmediatePropagation();" style="color:#00ffcc; font-size:14px; display:block; text-align:center; margin-top:10px; text-decoration:underline;">立即了解 →</a>
